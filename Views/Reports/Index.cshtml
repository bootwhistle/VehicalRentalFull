@model ReportViewModel
@{
    ViewData["Title"] = "Reports";
}

<div class="page-header">
    <h2 class="fw-bold mb-0"><i class="bi bi-bar-chart-line me-2" style="color:#4fc3f7;"></i>Reports</h2>
</div>

<!-- Filter Panel -->
<div class="card p-4 mb-4">
    <h6 class="fw-semibold mb-3" style="color:#4fc3f7;">
        <i class="bi bi-funnel me-2"></i>Filter Options
    </h6>
    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label asp-for="StartDate" class="form-label small fw-semibold"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="EndDate" class="form-label small fw-semibold"></label>
                <input asp-for="EndDate" class="form-control" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="Category" class="form-label small fw-semibold"></label>
                <select asp-for="Category" class="form-select">
                    <option value="">All Categories</option>
                    <option value="Sedan">Sedan</option>
                    <option value="SUV">SUV</option>
                    <option value="Truck">Truck</option>
                    <option value="Van">Van</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-bar-chart me-1"></i>Generate Report
                </button>
            </div>
        </div>
    </form>
</div>

@if (Model.Results != null)
{
    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="summary-card text-center">
                <div class="text-muted small mb-1">Total Revenue</div>
                <div style="font-size:1.8rem;font-weight:700;color:#4fc3f7;">$@Model.TotalRevenue.ToString("N2")</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card">
                <div class="text-muted small mb-1"><i class="bi bi-trophy me-1" style="color:#fff176;"></i>Most Rented Vehicle</div>
                <div class="fw-semibold" style="color:#fff176;">
                    @(string.IsNullOrEmpty(Model.MostRentedVehicle) ? "N/A" : Model.MostRentedVehicle)
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card">
                <div class="text-muted small mb-1"><i class="bi bi-star me-1" style="color:#ce93d8;"></i>Top Customer</div>
                <div class="fw-semibold" style="color:#ce93d8;">
                    @(string.IsNullOrEmpty(Model.TopCustomer) ? "N/A" : Model.TopCustomer)
                </div>
            </div>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card p-0 overflow-hidden">
        <div class="d-flex justify-content-between align-items-center px-4 py-3" style="border-bottom:1px solid #1e3a5f;">
            <h6 class="mb-0 fw-semibold">Results — @Model.Results.Count record(s)</h6>
        </div>
        @if (Model.Results.Any())
        {
            <div class="table-responsive">
                <table class="mb-0">
                    <thead>
                        <tr>
                            <th>Reservation #</th>
                            <th>Customer</th>
                            <th>Vehicle</th>
                            <th class="text-center">Rental Days</th>
                            <th class="text-end">Total Billed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Results)
                        {
                            <tr>
                                <td class="text-muted small">#@item.ReservationId</td>
                                <td class="fw-semibold">@item.CustomerName</td>
                                <td class="small">@item.VehicleName</td>
                                <td class="text-center">@item.RentalDays</td>
                                <td class="text-end fw-semibold" style="color:#4fc3f7;">$@item.TotalBilled.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background:#0f3460;">
                            <td colspan="3" class="fw-bold py-3 px-3">TOTALS</td>
                            <td class="text-center fw-bold">@Model.Results.Sum(r => r.RentalDays)</td>
                            <td class="text-end fw-bold py-3 px-3" style="color:#4fc3f7;font-size:1.05rem;">
                                $@Model.TotalRevenue.ToString("N2")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-search" style="font-size:2rem;"></i>
                <p class="mt-2">No reservations match the selected filters.</p>
            </div>
        }
    </div>
}
