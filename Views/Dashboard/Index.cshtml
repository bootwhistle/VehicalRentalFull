@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h2 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2" style="color:#4fc3f7;"></i>Dashboard</h2>
    <span class="text-muted small">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</span>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="card card-stat stat-blue">
            <div class="icon"><i class="bi bi-car-front"></i></div>
            <div class="number">@Model.TotalVehicles</div>
            <div class="label">Total Vehicles</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card card-stat stat-green">
            <div class="icon"><i class="bi bi-check-circle"></i></div>
            <div class="number">@Model.AvailableVehicles</div>
            <div class="label">Available Vehicles</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card card-stat stat-yellow">
            <div class="icon"><i class="bi bi-calendar-check"></i></div>
            <div class="number">@Model.ActiveReservations</div>
            <div class="label">Active Reservations</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card card-stat stat-purple">
            <div class="icon"><i class="bi bi-person-plus"></i></div>
            <div class="number">@Model.NewCustomersThisMonth</div>
            <div class="label">New Customers (Month)</div>
        </div>
    </div>
</div>

<!-- Quick Action Buttons -->
<div class="row g-2 mb-4">
    <div class="col-auto">
        <a asp-controller="Reservations" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>New Reservation
        </a>
    </div>
    <div class="col-auto">
        <a asp-controller="Vehicles" asp-action="Create" class="btn btn-outline-info btn-sm" style="border-color:#4fc3f7;color:#4fc3f7;">
            <i class="bi bi-plus-circle me-1"></i>Add Vehicle
        </a>
    </div>
    <div class="col-auto">
        <a asp-controller="Customers" asp-action="Create" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-person-plus me-1"></i>Add Customer
        </a>
    </div>
</div>

<!-- Recent Reservations -->
<div class="card p-0 overflow-hidden">
    <div class="d-flex justify-content-between align-items-center px-4 py-3" style="border-bottom:1px solid #1e3a5f;">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2" style="color:#4fc3f7;"></i>Recent Reservations</h5>
        <a asp-controller="Reservations" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
    </div>
    @if (Model.RecentReservations.Any())
    {
        <div class="table-responsive">
            <table class="mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.RecentReservations)
                    {
                        <tr>
                            <td class="text-muted small">#@r.ReservationId</td>
                            <td>@r.CustomerName</td>
                            <td class="text-muted small">@r.VehicleName</td>
                            <td class="text-muted small">@r.StartDate.ToString("MMM dd, yyyy")</td>
                            <td class="text-muted small">@r.EndDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @{
                                    var badgeClass = r.Status switch
                                    {
                                        "Confirmed" => "badge-confirmed",
                                        "Pending" => "badge-pending",
                                        "Cancelled" => "badge-cancelled",
                                        _ => "badge-pending"
                                    };
                                }
                                <span class="badge @badgeClass">@r.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x" style="font-size:2rem;"></i>
            <p class="mt-2">No reservations yet.</p>
        </div>
    }
</div>
