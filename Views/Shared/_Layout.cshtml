<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VehicleRental</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@(ViewBag.IsAuthPage == true ? "auth-page" : "")">

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-car-front-fill me-2" style="color:#4fc3f7;"></i>VehicleRental
            </a>
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="text-secondary small">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </button>
                    </form>
                </div>
            }
        </div>
    </nav>

    @if (User.Identity != null && User.Identity.IsAuthenticated && ViewBag.IsAuthPage != true)
    {
        <!-- Sidebar -->
        <div class="sidebar">
            <nav class="pt-2">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2 nav-icon"></i>Dashboard
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vehicles" ? "active" : "")"
                   asp-controller="Vehicles" asp-action="Index">
                    <i class="bi bi-car-front nav-icon"></i>Vehicles
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservations" ? "active" : "")"
                   asp-controller="Reservations" asp-action="Index">
                    <i class="bi bi-calendar-check nav-icon"></i>Reservations
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")"
                   asp-controller="Customers" asp-action="Index">
                    <i class="bi bi-people nav-icon"></i>Customers
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" ? "active" : "")"
                   asp-controller="Billing" asp-action="Index">
                    <i class="bi bi-receipt nav-icon"></i>Billing
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")"
                   asp-controller="Reports" asp-action="Index">
                    <i class="bi bi-bar-chart-line nav-icon"></i>Reports
                </a>
            </nav>
        </div>
    }

    <!-- Main Content -->
    <main class="main-content" style="@(ViewBag.IsAuthPage == true || (User.Identity == null || !User.Identity.IsAuthenticated) ? "margin-left:0;" : "")">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
