@model Customer
@{
    ViewData["Title"] = "Delete Customer";
}

<div class="page-header">
    <h2 class="fw-bold mb-0 text-danger"><i class="bi bi-person-x me-2"></i>Delete Customer</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Customers
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card p-4" style="border-color:#b71c1c;">
            <div class="text-center mb-4">
                <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size:3rem;"></i>
                <h4 class="mt-3">Are you sure?</h4>
                <p class="text-muted">This will permanently delete the customer record.</p>
                <p class="small text-warning">
                    <i class="bi bi-info-circle me-1"></i>
                    Customers with existing reservations cannot be deleted.
                </p>
            </div>

            <div class="p-3 mb-4" style="background:#0d1117;border-radius:8px;border:1px solid #1e3a5f;">
                <div class="row g-2">
                    <div class="col-6">
                        <span class="text-muted small">Full Name</span>
                        <div class="fw-semibold">@Model.FullName</div>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">Email</span>
                        <div class="small">@Model.Email</div>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">Phone</span>
                        <div class="small">@Model.Phone</div>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">License #</span>
                        <div class="font-monospace small">@Model.LicenseNumber</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="col-12">
                            <span class="text-muted small">Address</span>
                            <div class="small">@Model.Address</div>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <form asp-action="DeleteConfirmed" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.CustomerId" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Yes, Delete
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </a>
            </div>
        </div>
    </div>
</div>
