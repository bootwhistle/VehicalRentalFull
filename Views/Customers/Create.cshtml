@model Customer
@{
    ViewData["Title"] = "Add Customer";
}

<div class="page-header">
    <h2 class="fw-bold mb-0"><i class="bi bi-person-plus me-2" style="color:#4fc3f7;"></i>Add Customer</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Customers
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="FullName" class="form-label small fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" placeholder="John Smith" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label small fw-semibold"></label>
                        <input asp-for="Email" class="form-control" placeholder="john@example.com" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label small fw-semibold"></label>
                        <input asp-for="Phone" class="form-control" placeholder="403-555-0100" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LicenseNumber" class="form-label small fw-semibold"></label>
                        <input asp-for="LicenseNumber" class="form-control font-monospace" placeholder="DL-123456" />
                        <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Address" class="form-label small fw-semibold">Address <span class="text-muted">(optional)</span></label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="123 Main St, Calgary, AB"></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-person-check me-1"></i>Add Customer
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScripts.partial")
}
