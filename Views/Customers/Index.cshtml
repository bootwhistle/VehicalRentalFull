@model IEnumerable<Customer>
@{
    ViewData["Title"] = "Customers";
    var search = ViewBag.Search as string;
}

<div class="page-header">
    <h2 class="fw-bold mb-0"><i class="bi bi-people me-2" style="color:#4fc3f7;"></i>Customers</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Add Customer
    </a>
</div>

<!-- Search Bar -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width:420px;">
        <input type="text" name="search" value="@search" class="form-control"
               placeholder="Search by name, email, or license..." />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i>
        </button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg"></i>
            </a>
        }
    </div>
</form>

@if (!string.IsNullOrEmpty(search))
{
    <p class="text-muted small mb-3">
        Showing results for "<strong>@search</strong>" — @Model.Count() found
    </p>
}

<div class="card p-0 overflow-hidden">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>License #</th>
                        <th>Member Since</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="text-muted small">@c.CustomerId</td>
                            <td class="fw-semibold">@c.FullName</td>
                            <td class="small">@c.Email</td>
                            <td class="small">@c.Phone</td>
                            <td class="font-monospace small">@c.LicenseNumber</td>
                            <td class="text-muted small">@c.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@c.CustomerId" class="btn btn-sm btn-outline-secondary me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@c.CustomerId" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-person-x" style="font-size:2rem;"></i>
            <p class="mt-2">
                @if (!string.IsNullOrEmpty(search))
                {
                    <span>No customers match your search. <a asp-action="Index" style="color:#4fc3f7;">Clear search.</a></span>
                }
                else
                {
                    <span>No customers yet. <a asp-action="Create" style="color:#4fc3f7;">Add one now.</a></span>
                }
            </p>
        </div>
    }
</div>
