@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewBag.IsAuthPage = true;
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height:100vh; padding-top:56px;">
    <div class="card p-4" style="width:100%;max-width:420px;">
        <div class="text-center mb-4">
            <i class="bi bi-car-front-fill" style="font-size:2.5rem;color:#4fc3f7;"></i>
            <h3 class="mt-2 fw-bold">VehicleRental</h3>
            <p class="text-muted small">Sign in to your account</p>
        </div>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#0d1117;border-color:#1e3a5f;color:#888;">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label small fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#0d1117;border-color:#1e3a5f;color:#888;">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input asp-for="Password" class="form-control" placeholder="••••••" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 d-flex align-items-center">
                <input asp-for="RememberMe" class="form-check-input me-2" />
                <label asp-for="RememberMe" class="form-check-label small">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>
        </form>

        <hr style="border-color:#1e3a5f;" class="my-4" />
        <p class="text-center small text-muted mb-0">
            Don't have an account?
            <a asp-action="Register" style="color:#4fc3f7;">Register here</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScripts.partial")
}
