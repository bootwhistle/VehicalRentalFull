@model Billing
@{
    Layout = null;
    var reservation = Model.Reservation;
    var customer = reservation?.Customer;
    var vehicle = reservation?.Vehicle;
    int rentalDays = reservation != null ? Math.Max(1, (reservation.EndDate - reservation.StartDate).Days) : 1;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice #@Model.BillingId — VehicleRental</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #fff; color: #222; padding: 40px; max-width: 700px; margin: 0 auto; }
        .invoice-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 2px solid #0f3460; }
        .brand { font-size: 1.8rem; font-weight: 700; color: #0f3460; }
        .brand span { color: #4fc3f7; }
        .invoice-meta { text-align: right; color: #555; }
        .invoice-meta .inv-num { font-size: 1.2rem; font-weight: 700; color: #0f3460; }
        .section { margin-bottom: 25px; }
        .section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 8px; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px 20px; }
        .info-item label { font-size: 0.78rem; color: #888; display: block; }
        .info-item span { font-weight: 600; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        table th { background: #0f3460; color: #fff; padding: 10px 12px; text-align: left; font-size: 0.85rem; }
        table td { padding: 10px 12px; border-bottom: 1px solid #e0e0e0; font-size: 0.9rem; }
        .totals-table { width: 100%; max-width: 320px; margin-left: auto; }
        .totals-table td { padding: 6px 12px; }
        .totals-table .grand-total td { border-top: 2px solid #0f3460; font-weight: 700; font-size: 1.05rem; color: #0f3460; }
        .status-badge { display: inline-block; padding: 4px 14px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; }
        .badge-paid { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
        .badge-unpaid { background: #fce4ec; color: #c62828; border: 1px solid #ef9a9a; }
        .footer { text-align: center; margin-top: 40px; padding-top: 20px; border-top: 1px solid #e0e0e0; color: #888; font-size: 0.82rem; }
        .print-btn { position: fixed; top: 20px; right: 20px; background: #0f3460; color: #fff; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 0.9rem; }
        @@media print {
            .print-btn { display: none; }
            body { padding: 20px; }
        }
    </style>
</head>
<body>
    <button class="print-btn" onclick="window.print()">
        &#128438; Print Invoice
    </button>

    <div class="invoice-header">
        <div>
            <div class="brand">Vehicle<span>Rental</span></div>
            <div style="color:#555;font-size:0.85rem;margin-top:5px;">Vehicle Rental Management System</div>
        </div>
        <div class="invoice-meta">
            <div class="inv-num">INVOICE #@Model.BillingId</div>
            <div>Generated: @DateTime.Now.ToString("MMM dd, yyyy")</div>
            <div style="margin-top:8px;">
                @if (Model.IsPaid)
                {
                    <span class="status-badge badge-paid">PAID</span>
                }
                else
                {
                    <span class="status-badge badge-unpaid">UNPAID</span>
                }
            </div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:30px;margin-bottom:30px;">
        <div class="section">
            <div class="section-title">Bill To</div>
            @if (customer != null)
            {
                <div style="font-weight:700;font-size:1.05rem;">@customer.FullName</div>
                <div style="color:#555;">@customer.Email</div>
                <div style="color:#555;">@customer.Phone</div>
                <div style="color:#555;font-size:0.85rem;">License: @customer.LicenseNumber</div>
                @if (!string.IsNullOrEmpty(customer.Address))
                {
                    <div style="color:#555;font-size:0.85rem;">@customer.Address</div>
                }
            }
        </div>
        <div class="section">
            <div class="section-title">Vehicle</div>
            @if (vehicle != null)
            {
                <div style="font-weight:700;font-size:1.05rem;">@vehicle.Year @vehicle.Make @vehicle.Model</div>
                <div style="color:#555;">Category: @vehicle.Category</div>
                <div style="color:#555;">Plate: @vehicle.LicensePlate</div>
                <div style="color:#555;">Daily Rate: $@vehicle.DailyRate.ToString("N2")</div>
            }
        </div>
    </div>

    <div class="section">
        <div class="section-title">Rental Period</div>
        <table>
            <thead>
                <tr>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Days</th>
                    <th>Daily Rate</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@reservation?.StartDate.ToString("MMM dd, yyyy")</td>
                    <td>@reservation?.EndDate.ToString("MMM dd, yyyy")</td>
                    <td>@rentalDays</td>
                    <td>$@vehicle?.DailyRate.ToString("N2")</td>
                    <td>@reservation?.Status</td>
                </tr>
            </tbody>
        </table>
    </div>

    <table class="totals-table">
        <tr>
            <td style="color:#555;">Base Cost (@rentalDays days × $@vehicle?.DailyRate.ToString("N2"))</td>
            <td style="text-align:right;">$@Model.BaseCost.ToString("N2")</td>
        </tr>
        <tr>
            <td style="color:#555;">Tax (10%)</td>
            <td style="text-align:right;">$@Model.TaxAmount.ToString("N2")</td>
        </tr>
        <tr>
            <td style="color:#555;">Additional Charges</td>
            <td style="text-align:right;">$@Model.AdditionalCharges.ToString("N2")</td>
        </tr>
        <tr class="grand-total">
            <td>TOTAL DUE</td>
            <td style="text-align:right;">$@Model.TotalAmount.ToString("N2")</td>
        </tr>
    </table>

    @if (Model.IsPaid && Model.PaidAt.HasValue)
    {
        <div style="margin-top:20px;padding:12px 16px;background:#e8f5e9;border-radius:6px;color:#2e7d32;font-size:0.88rem;">
            <strong>Payment received</strong> on @Model.PaidAt.Value.ToString("MMMM dd, yyyy 'at' h:mm tt")
        </div>
    }

    <div class="footer">
        <p>Thank you for choosing VehicleRental!</p>
        <p>This is an automatically generated invoice. For inquiries, contact our office.</p>
    </div>
</body>
</html>
