@model IEnumerable<Billing>
@{
    ViewData["Title"] = "Billing";
}

<div class="page-header">
    <h2 class="fw-bold mb-0"><i class="bi bi-receipt me-2" style="color:#4fc3f7;"></i>Billing</h2>
    <div class="text-muted small">
        Total: <strong style="color:#81c784;">$@Model.Sum(b => b.TotalAmount).ToString("N2")</strong>
        &nbsp;|&nbsp;
        Paid: <strong style="color:#81c784;">$@Model.Where(b => b.IsPaid).Sum(b => b.TotalAmount).ToString("N2")</strong>
        &nbsp;|&nbsp;
        Outstanding: <strong style="color:#ef9a9a;">$@Model.Where(b => !b.IsPaid).Sum(b => b.TotalAmount).ToString("N2")</strong>
    </div>
</div>

<div class="card p-0 overflow-hidden">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Reservation Dates</th>
                        <th>Base Cost</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td class="text-muted small">#@b.BillingId</td>
                            <td class="fw-semibold">@(b.Reservation?.Customer?.FullName ?? "-")</td>
                            <td class="small">
                                @if (b.Reservation?.Vehicle != null)
                                {
                                    @($"{b.Reservation.Vehicle.Year} {b.Reservation.Vehicle.Make} {b.Reservation.Vehicle.Model}")
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @if (b.Reservation != null)
                                {
                                    @($"{b.Reservation.StartDate:MMM dd} – {b.Reservation.EndDate:MMM dd, yyyy}")
                                }
                            </td>
                            <td>$@b.BaseCost.ToString("N2")</td>
                            <td class="fw-semibold" style="color:#4fc3f7;">$@b.TotalAmount.ToString("N2")</td>
                            <td>
                                @if (b.IsPaid)
                                {
                                    <span class="badge badge-paid">Paid</span>
                                }
                                else
                                {
                                    <span class="badge badge-unpaid">Unpaid</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@b.BillingId" class="btn btn-sm btn-outline-secondary" title="Details">
                                    <i class="bi bi-eye me-1"></i>Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-receipt" style="font-size:2rem;"></i>
            <p class="mt-2">No billing records yet.</p>
        </div>
    }
</div>
