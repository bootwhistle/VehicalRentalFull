@model Billing
@{
    ViewData["Title"] = $"Billing #{Model.BillingId}";
    var reservation = Model.Reservation;
    var customer = reservation?.Customer;
    var vehicle = reservation?.Vehicle;
    int rentalDays = reservation != null ? Math.Max(1, (reservation.EndDate - reservation.StartDate).Days) : 1;
}

<div class="page-header">
    <h2 class="fw-bold mb-0"><i class="bi bi-receipt me-2" style="color:#4fc3f7;"></i>Billing Details — #@Model.BillingId</h2>
    <div class="d-flex gap-2">
        <a asp-action="Invoice" asp-route-id="@Model.BillingId" class="btn btn-outline-secondary" target="_blank">
            <i class="bi bi-printer me-1"></i>Invoice
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Customer & Vehicle Info -->
    <div class="col-md-6">
        <div class="card p-4 h-100">
            <h6 class="fw-semibold mb-3" style="color:#4fc3f7;border-bottom:1px solid #1e3a5f;padding-bottom:8px;">
                <i class="bi bi-person me-2"></i>Customer
            </h6>
            @if (customer != null)
            {
                <div class="mb-2"><span class="text-muted small">Name:</span> <strong>@customer.FullName</strong></div>
                <div class="mb-2"><span class="text-muted small">Email:</span> @customer.Email</div>
                <div class="mb-2"><span class="text-muted small">Phone:</span> @customer.Phone</div>
                <div class="mb-2"><span class="text-muted small">License #:</span> <span class="font-monospace">@customer.LicenseNumber</span></div>
            }
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-4 h-100">
            <h6 class="fw-semibold mb-3" style="color:#4fc3f7;border-bottom:1px solid #1e3a5f;padding-bottom:8px;">
                <i class="bi bi-car-front me-2"></i>Vehicle
            </h6>
            @if (vehicle != null)
            {
                <div class="mb-2"><span class="text-muted small">Vehicle:</span> <strong>@vehicle.Year @vehicle.Make @vehicle.Model</strong></div>
                <div class="mb-2"><span class="text-muted small">Category:</span> @vehicle.Category</div>
                <div class="mb-2"><span class="text-muted small">License Plate:</span> <span class="font-monospace">@vehicle.LicensePlate</span></div>
                <div class="mb-2"><span class="text-muted small">Daily Rate:</span> <strong style="color:#81c784;">$@vehicle.DailyRate.ToString("N2")</strong></div>
            }
        </div>
    </div>

    <!-- Rental Period -->
    <div class="col-12">
        <div class="card p-4">
            <h6 class="fw-semibold mb-3" style="color:#4fc3f7;border-bottom:1px solid #1e3a5f;padding-bottom:8px;">
                <i class="bi bi-calendar-range me-2"></i>Rental Period
            </h6>
            <div class="row">
                <div class="col-md-3">
                    <span class="text-muted small">Start Date</span>
                    <div class="fw-semibold">@reservation?.StartDate.ToString("dddd, MMM dd, yyyy")</div>
                </div>
                <div class="col-md-3">
                    <span class="text-muted small">End Date</span>
                    <div class="fw-semibold">@reservation?.EndDate.ToString("dddd, MMM dd, yyyy")</div>
                </div>
                <div class="col-md-3">
                    <span class="text-muted small">Duration</span>
                    <div class="fw-semibold">@rentalDays day(s)</div>
                </div>
                <div class="col-md-3">
                    <span class="text-muted small">Status</span>
                    <div>
                        @{
                            var badgeClass = reservation?.Status switch
                            {
                                "Confirmed" => "badge-confirmed",
                                "Pending" => "badge-pending",
                                "Cancelled" => "badge-cancelled",
                                _ => "badge-pending"
                            };
                        }
                        <span class="badge @badgeClass">@reservation?.Status</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Billing Breakdown -->
    <div class="col-12">
        <div class="card p-4">
            <h6 class="fw-semibold mb-3" style="color:#4fc3f7;border-bottom:1px solid #1e3a5f;padding-bottom:8px;">
                <i class="bi bi-calculator me-2"></i>Billing Breakdown
            </h6>
            <div class="row" style="max-width:500px;">
                <div class="col-8 py-2 border-bottom" style="border-color:#1e3a5f!important;">
                    <span class="text-muted">Base Cost</span>
                    <div class="small text-muted">(@rentalDays day(s) × $@vehicle?.DailyRate.ToString("N2"))</div>
                </div>
                <div class="col-4 py-2 border-bottom text-end fw-semibold" style="border-color:#1e3a5f!important;">
                    $@Model.BaseCost.ToString("N2")
                </div>

                <div class="col-8 py-2 border-bottom text-muted" style="border-color:#1e3a5f!important;">Tax (10%)</div>
                <div class="col-4 py-2 border-bottom text-end" style="border-color:#1e3a5f!important;">
                    $@Model.TaxAmount.ToString("N2")
                </div>

                <div class="col-8 py-2 border-bottom text-muted" style="border-color:#1e3a5f!important;">Additional Charges</div>
                <div class="col-4 py-2 border-bottom text-end" style="border-color:#1e3a5f!important;">
                    $@Model.AdditionalCharges.ToString("N2")
                </div>

                <div class="col-8 py-3 fw-bold" style="font-size:1.1rem;">GRAND TOTAL</div>
                <div class="col-4 py-3 text-end fw-bold" style="color:#4fc3f7;font-size:1.2rem;">
                    $@Model.TotalAmount.ToString("N2")
                </div>
            </div>

            <div class="mt-3 pt-3" style="border-top:1px solid #1e3a5f;">
                @if (Model.IsPaid)
                {
                    <div>
                        <span class="badge badge-paid px-3 py-2" style="font-size:0.9rem;">
                            <i class="bi bi-check-circle-fill me-2"></i>PAID
                        </span>
                        <span class="text-muted small ms-3">
                            Paid on @Model.PaidAt?.ToString("MMMM dd, yyyy 'at' h:mm tt")
                        </span>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-3">
                        <span class="badge badge-unpaid px-3 py-2" style="font-size:0.9rem;">
                            <i class="bi bi-exclamation-circle me-1"></i>UNPAID
                        </span>
                        <form asp-action="MarkPaid" asp-route-id="@Model.BillingId" method="post" class="d-inline"
                              onsubmit="return confirm('Mark this billing as paid?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success btn-sm px-3">
                                <i class="bi bi-check-circle me-1"></i>Mark as Paid
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
