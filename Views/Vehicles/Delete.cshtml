@model Vehicle
@{
    ViewData["Title"] = "Delete Vehicle";
}

<div class="page-header">
    <h2 class="fw-bold mb-0 text-danger"><i class="bi bi-trash me-2"></i>Delete Vehicle</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Vehicles
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card p-4" style="border-color:#b71c1c;">
            <div class="text-center mb-4">
                <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size:3rem;"></i>
                <h4 class="mt-3">Are you sure?</h4>
                <p class="text-muted">This action cannot be undone.</p>
            </div>

            <div class="p-3 mb-4" style="background:#0d1117;border-radius:8px;border:1px solid #1e3a5f;">
                <div class="row g-2">
                    <div class="col-6">
                        <span class="text-muted small">Vehicle</span>
                        <div class="fw-semibold">@Model.Year @Model.Make @Model.Model</div>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">License Plate</span>
                        <div class="fw-semibold font-monospace">@Model.LicensePlate</div>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">Category</span>
                        <div>@Model.Category</div>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">Daily Rate</span>
                        <div style="color:#81c784;">$@Model.DailyRate.ToString("N2")</div>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">Status</span>
                        <div>
                            @if (Model.IsAvailable)
                            {
                                <span class="badge badge-available">Available</span>
                            }
                            else
                            {
                                <span class="badge badge-rented">Rented</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <form asp-action="DeleteConfirmed" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.VehicleId" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Yes, Delete
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </a>
            </div>
        </div>
    </div>
</div>
